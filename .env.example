# Required in production (min 32 characters)
WORKOUT_SESSION_SECRET=

# Required in production — app login password (never exposed to the client bundle)
WORKOUT_APP_PASSWORD=

# Workouts are read at runtime from data/workouts.json (repo root). Run the server
# with cwd set to the project root so that path resolves.

# --- GitHub Pages (`npm run build:pages`; CI sets these) ---
# GITHUB_PAGES=true
# VITE_GH_PAGES=true
# VITE_BASE_PATH=/my-repo/
# Client-only gate on static deploy (compiled into JS). Use repo secret PAGES_APP_PASSWORD in Actions.
# VITE_PAGES_PASSWORD=
